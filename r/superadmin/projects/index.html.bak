        </div>
    </div>

    <!-- MODAL TUTORIAL -->
    <div id="tutorialModal" class="fixed inset-0 z-[100] hidden" aria-labelledby="modal-title" role="dialog" aria-modal="true">
        <div class="fixed inset-0 bg-black/80 backdrop-blur-sm transition-opacity" onclick="cerrarTutorial()"></div>
        <div class="fixed inset-0 z-10 overflow-y-auto">
            <div class="flex min-h-full items-center justify-center p-4 text-center sm:p-0 animate-fade-in">
                <div class="relative transform overflow-hidden rounded-2xl bg-slate-900 text-left shadow-2xl transition-all sm:my-8 sm:w-full sm:max-w-2xl border border-white/10">
                    <div class="bg-indigo-600 px-6 py-4 flex justify-between items-center border-b border-white/5">
                        <h3 class="text-lg font-bold text-white flex items-center gap-2"><span>🎓</span> <span id="tutTitle">Tutorial</span></h3>
                        <button type="button" class="text-indigo-100 hover:text-white text-2xl leading-none focus:outline-none" onclick="cerrarTutorial()">&times;</button>
                    </div>
                    <div class="px-6 py-6 text-slate-300">
                        <div id="tutVideoContainer" class="aspect-video w-full rounded-xl overflow-hidden bg-black mb-6 shadow-md hidden">
                            <iframe id="tutVideoFrame" class="w-full h-full" src="" title="Video Tutorial" frameborder="0" allowfullscreen></iframe>
                        </div>
                        <div class="space-y-4">
                            <h4 class="font-semibold text-slate-200 border-b border-white/5 pb-2">Pasos a seguir:</h4>
                            <ul id="tutSteps" class="list-none space-y-3 text-sm text-slate-400"></ul>
                        </div>
                    </div>
                    <div class="bg-slate-950/60 px-6 py-3 flex justify-end border-t border-white/5">
                        <button type="button" class="inline-flex w-full justify-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-indigo-500" onclick="cerrarTutorial()">Entendido</button>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- SCRIPTS -->
    <script>
        // ==========================================
        // 1. CONFIGURACIÓN Y CONSTANTES GLOBALES
        // ==========================================
        const API_URL = 'https://gestordecursos.pegui.edu.co:8000';
        const API_GEMINI = `${API_URL}/chat/gemini`;
        const API_WHISPER = `${API_URL}/whisper/transcribir`;

        // Almacenamiento de proyectos y caché
        let todosProyectos = [];
        let clientesCache = {};
        let peticionesEnCurso = {};
        
        // Variables para Participantes y Grabación Whisper
        let usuariosSistema = [];
        let idProyectoParticipantesActivo = null;
        let mediaRecorder = null;
        let audioChunks = [];
        let idCampoDestino = null;
        let temporizadorMaximo = null;
        let estaGrabando = false; // Declarada de forma única y global

        const rolesMap = {
            1: "Superadmin",
            2: "Admin",
            3: "Coordinador",
            4: "Cliente",
            5: "Diseñador Instruccional",
            6: "Autor",
            7: "Revisor QA",
            8: "Editor",
            9: "Desarrollador Multimedia",
            10: "Abogado",
            11: "Diseñador Gráfico",
            12: "Animador 2D",
            13: "Animador 3D",
            14: "Video",
            16: "Corrector de Estilo",
            17: "Ingeniero LMS",
            18: "Registrado"
        };

        function getToken() {
            return localStorage.getItem('token') || sessionStorage.getItem('token');
        }

        // --- SISTEMAS DE GRABACIÓN WHISPER (PRO - UNIFICADO Y CORREGIDO) ---
        async function gestionarGrabacionWhisper(e, idCampo) {
            if (e) {
                e.preventDefault();
                e.stopPropagation();
            }
            if (estaGrabando && idCampoDestino === idCampo) {
                if (mediaRecorder && mediaRecorder.state !== 'inactive') mediaRecorder.stop();
                return;
            }
            if (estaGrabando) {
                if (mediaRecorder && mediaRecorder.state !== 'inactive') mediaRecorder.stop();
                await new Promise(r => setTimeout(r, 150));
            }

            idCampoDestino = idCampo;
            audioChunks = [];
            estaGrabando = true;

            try {
                const stream = await navigator.mediaDevices.getUserMedia({ audio: true });
                mediaRecorder = new MediaRecorder(stream, { mimeType: 'audio/webm;codecs=opus' });
                
                mediaRecorder.ondataavailable = (ev) => {
                    if (ev.data && ev.data.size > 0) audioChunks.push(ev.data);
                };

                mediaRecorder.onstart = () => {
                    resetearIconosMic();
                    const btn = document.getElementById(`btn-mic-${idCampoDestino}`);
                    const ico = document.getElementById(`ico-mic-${idCampoDestino}`);
                    if (btn) btn.classList.add('mic-recording');
                    if (ico) ico.className = 'fas fa-stop text-lg';
                    temporizadorMaximo = setTimeout(() => {
                        if (mediaRecorder && mediaRecorder.state === 'recording') mediaRecorder.stop();
                    }, 10000);
                };

                mediaRecorder.onstop = async () => {
                    clearTimeout(temporizadorMaximo);
                    estaGrabando = false;
                    const btn = document.getElementById(`btn-mic-${idCampoDestino}`);
                    const ico = document.getElementById(`ico-mic-${idCampoDestino}`);
                    if (btn) {
                        btn.classList.remove('mic-recording');
                        btn.classList.add('mic-processing');
                    }
                    if (ico) ico.className = 'fas fa-spinner fa-spin text-lg';
                    const blob = new Blob(audioChunks, { type: 'audio/webm;codecs=opus' });
                    stream.getTracks().forEach(t => t.stop());
                    
                    if (blob.size > 100) {
                        await enviarAudioAWhisper(blob);
                    } else {
                        resetearIconosMic();
                    }
                };

                mediaRecorder.start();
            } catch (err) {
                estaGrabando = false;
                console.error('Whisper error:', err);
                resetearIconosMic();
            }
        }

        async function enviarAudioAWhisper(blob) {
            if (!blob || blob.size === 0) {
                resetearIconosMic();
                return;
            }
            const token = getToken();
            const fd = new FormData();
            fd.append('audio', blob, 'dictado.webm');
            try {
                const res = await fetch(API_WHISPER, {
                    method: 'POST',
                    headers: { 'Authorization': 'Bearer ' + token },
                    body: fd
                });
                if (!res.ok) throw new Error('Error Whisper');
                const data = await res.json();
                const texto = (data.texto || '').trim();
                if (texto) {
                    const input = document.getElementById(idCampoDestino);
                    if (input) {
                        input.value = input.value.trim() ? input.value.trim() + ' ' + texto : texto;
                        input.dispatchEvent(new Event('input', { bubbles: true }));
                    }
                }
            } catch (err) {
                console.error('Whisper fetch error:', err);
            } finally {
                resetearIconosMic();
            }
        }

        function resetearIconosMic() {
            document.querySelectorAll('[id^="btn-mic-"]').forEach(function(b) {
                const id = b.id.replace('btn-mic-', '');
                b.className = "btn-mic-premium h-12";
                if (id === 'description') {
                    b.className = "btn-mic-premium h-[104px]";
                }
                if (id === 'observaciones') {
                    b.className = "btn-mic-premium h-[84px]";
                }
            });
            document.querySelectorAll('[id^="ico-mic-"]').forEach(function(i) {
                i.className = 'fas fa-microphone text-lg';
            });
            if (!estaGrabando) idCampoDestino = null;
        }

        // --- LÓGICA DE NAVEGACIÓN (TABS) ---
        function switchView(viewName) {
            const vistaDashboard = document.getElementById('vistaDashboard');
            const vistaCreacion = document.getElementById('vistaCreacion');
            const btnTabDashboard = document.getElementById('btnTabDashboard');
            const btnTabCreacion = document.getElementById('btnTabCreacion');

            if(viewName === 'dashboard') {
                vistaDashboard.classList.remove('hidden-view');
                vistaCreacion.classList.add('hidden-view');
                btnTabDashboard.classList.add('tab-active');
                btnTabDashboard.classList.remove('tab-inactive');
                btnTabCreacion.classList.add('tab-inactive');
                btnTabCreacion.classList.remove('tab-active');
                cargarProyectos(); // Refrescar tablero al reingresar
            } else {
                vistaDashboard.classList.add('hidden-view');
                vistaCreacion.classList.remove('hidden-view');
                btnTabCreacion.classList.add('tab-active');
                btnTabCreacion.classList.remove('tab-inactive');
                btnTabDashboard.classList.add('tab-inactive');
                btnTabDashboard.classList.remove('tab-active');
            }
        }

        // --- FUNCIONES DEL DASHBOARD ---
        function getBadge(estado) {
            const badges = {
                'Planificado': 'badge-planificado',
                'En desarrollo': 'badge-desarrollo',
                'Aprobado': 'badge-aprobado',
                'Aplazado': 'badge-aplazado',
                'Finalizado': 'badge-finalizado',
                'Cancelado': 'badge-cancelado'
            };
            return badges[estado] || 'bg-slate-800 text-slate-300';
        }

        async function getNombreCliente(client_id) {
            if (!client_id) return 'Sin cliente';
            if (clientesCache[client_id]) return clientesCache[client_id];
            if (peticionesEnCurso[client_id]) return peticionesEnCurso[client_id];

            peticionesEnCurso[client_id] = (async () => {
                try {
                    const resp = await fetch(`${API_URL}/users/${client_id}`, {
                        headers: { "Authorization": "Bearer " + getToken() }
                    });
                    if (resp.ok) {
                        const data = await resp.json();
                        const nombre = data.name || data.nombre || 'Cliente';
                        clientesCache[client_id] = nombre;
                        return nombre;
                    }
                } catch (e) {
                    console.warn("Error cargando cliente:", client_id);
                } finally {
                    delete peticionesEnCurso[client_id];
                }
                return 'Cliente';
            })();

            return peticionesEnCurso[client_id];
        }

        async function cargarProyectos() {
            const grid = document.getElementById('proyectosGrid');
            const token = getToken();
            if (!token) { window.location.href = '/login.html'; return; }

            grid.innerHTML = `
                <div class="col-span-full py-20 text-center">
                    <div class="inline-flex items-center gap-3 text-slate-400 text-lg">
                        <div class="w-8 h-8 border-3 border-indigo-500 border-t-transparent rounded-full loading-spinner"></div>
                        Consultando API...
                    </div>
                </div>
            `;

            try {
                const resp = await fetch(`${API_URL}/projects/`, {
                    headers: {
                        "Authorization": "Bearer " + token,
                        "Content-Type": "application/json"
                    }
                });
                
                if (!resp.ok) throw new Error("Error en la autenticación o servidor");
                todosProyectos = await resp.json();
                
                const promesasClientes = [...new Set(todosProyectos.map(p => p.client_id))]
                    .filter(id => id)
                    .map(id => getNombreCliente(id));
                    
                await Promise.all(promesasClientes);

                try {
                    const resCount = await fetch(`${API_URL}/participantes/counts`, { headers: { "Authorization": "Bearer " + token } });
                    if (resCount.ok) {
                        const counts = await resCount.json();
                        window.participantCounts = counts;
                    }
                } catch(e) { window.participantCounts = {}; }

                renderProyectos();
                actualizarStats();
            } catch (e) {
                grid.innerHTML = `
                    <div class="col-span-full py-20 text-center">
                        <div class="text-rose-500 text-4xl mb-4">⚠️</div>
                        <div class="text-rose-600 text-xl font-bold">Error de Conexión</div>
                        <p class="text-slate-400 mt-2">${e.message}</p>
                        <button onclick="cargarProyectos()" class="mt-6 bg-indigo-600 text-white px-8 py-3 rounded-xl hover:bg-indigo-700 transition-all shadow-lg text-sm font-semibold">Reintentar</button>
                    </div>
                `;
            }
        }

        function renderProyectos() {
            const grid = document.getElementById('proyectosGrid');
            const estadoFiltro = document.getElementById('filtroEstado').value;
            const clienteFiltro = document.getElementById('filtroCliente').value.toLowerCase();
            const nombreFiltro = document.getElementById('filtroNombre').value.toLowerCase();

            let proyectos = todosProyectos.filter(p => {
                const nombreCliente = (clientesCache[p.client_id] || '').toLowerCase();
                const matchEstado = !estadoFiltro || p.estado === estadoFiltro;
                const matchCliente = !clienteFiltro || nombreCliente.includes(clienteFiltro);
                const matchNombre = !nombreFiltro || (p.name || '').toLowerCase().includes(nombreFiltro);
                return matchEstado && matchCliente && matchNombre;
            });

            if (!proyectos.length) {
                grid.innerHTML = `
                    <div class="col-span-full py-20 text-center text-slate-500"> 
                         <span class="text-6xl block mb-4">📋</span>
                         <p class="text-lg font-medium">No se encontraron proyectos con estos criterios.</p>
                    </div>`;
                return;
            }

            grid.innerHTML = proyectos.map((proj, idx) => {
                const clienteNombre = clientesCache[proj.client_id] || 'Cliente VirtualMind';
                const inicial = clienteNombre.charAt(0).toUpperCase();
                
                return `
                    <div class="card-glass rounded-2xl overflow-hidden transition-all duration-300 hover:border-indigo-500/30 hover:shadow-2xl hover:shadow-indigo-500/5 animate-fade-in" style="animation-delay: ${idx * 0.03}s">
                        <div class="bg-slate-950/40 p-4 border-b border-white/5">
                            <div class="flex justify-between items-center">
                                <div class="flex items-center">
                                    <span class="inline-flex items-center justify-center w-7 h-7 bg-indigo-600 text-white rounded-lg text-xs font-bold shadow-md">${proj.id}</span>
                                    <span class="ml-2.5 badge-status ${getBadge(proj.estado)}">${proj.estado || 'Planificado'}</span>
                                    ${(window.participantCounts || {})[proj.id] > 0 ? '' : '<span class="ml-1.5 badge-status bg-amber-900/40 text-amber-400 border border-amber-600/30 text-[10px] px-2 py-0.5 rounded-full">⚠️ Sin colaboradores</span>'}
                                </div>
                                <span class="text-[10px] font-bold text-indigo-400 bg-indigo-500/10 border border-indigo-500/20 px-2 py-0.5 rounded-md uppercase tracking-wide">${proj.tipo_proyecto || 'E-learning'}</span>
                            </div>
                        </div>
                                                
                        <div class="p-5">
                            <h3 class="font-bold text-base text-slate-100 mb-3 truncate" title="${proj.name}">${proj.name || 'Sin título'}</h3>
                                                    
                            <div class="flex items-center gap-3 mb-4">
                                <div class="w-9 h-9 bg-gradient-to-br from-indigo-500 to-purple-600 rounded-full flex items-center justify-center text-white text-sm font-black shadow-md">${inicial}</div>
                                <div>
                                    <div class="text-xs font-bold text-slate-300">${clienteNombre}</div>
                                    <div class="text-[10px] text-slate-500 font-mono mt-0.5">${proj.codigo_referencia || 'VM-PROJECT'}</div>
                                </div>
                            </div>

                            <div class="grid grid-cols-2 gap-3 text-xs mb-4">
                                <div class="bg-slate-950/40 rounded-xl p-3 border border-white/5 shadow-inner">
                                    <div class="text-[10px] text-slate-500 font-semibold uppercase mb-1">📅 Inicio</div>
                                    <div class="font-bold text-slate-300 font-mono">${proj.start_date || '—'}</div>
                                </div>
                                <div class="bg-slate-950/40 rounded-xl p-3 border border-white/5 shadow-inner">
                                    <div class="text-[10px] text-slate-500 font-semibold uppercase mb-1">🏁 Fin</div>
                                    <div class="font-bold text-slate-300 font-mono">${proj.end_date || '—'}</div>
                                </div>
                            </div>

                            <p class="text-xs text-slate-400 line-clamp-2 mb-5 h-8 italic">"${proj.description || 'Sin descripción disponible'}"</p>

                            <div class="flex flex-wrap gap-1.5 border-t border-white/5 pt-4">
                                <button onclick="verProyecto(${proj.id})" class="flex-1 bg-indigo-600 hover:bg-indigo-500 text-white py-2 px-3 rounded-xl text-xs font-bold transition-all shadow-md active:scale-95">👁️ Ver</button>
                                <button onclick="verDocumentos(${proj.id})" class="bg-blue-500/10 hover:bg-blue-500/20 text-blue-400 px-3 py-2 rounded-xl text-xs font-bold transition-all border border-blue-500/20" title="Documentos del Proyecto">📁</button>
                                <button onclick="gestionarParticipantes(${proj.id}, '${proj.name.replace(/'/g, "\\'")}')" class="bg-purple-500/10 hover:bg-purple-500/20 text-purple-400 px-3 py-2 rounded-xl text-xs font-bold transition-all border border-purple-500/20" title="Gestionar Participantes">👥</button>
                                <button onclick="actualizarProyecto(${proj.id})" class="bg-slate-800 hover:bg-slate-700 text-slate-300 px-3 py-2 rounded-xl text-xs font-bold transition-all border border-white/5" title="Editar">✏️</button>
                                <button onclick="crearPlanFormacion(${proj.id})" class="bg-emerald-500/10 hover:bg-emerald-500/20 text-emerald-400 px-3 py-2 rounded-xl text-xs font-bold transition-all border border-emerald-500/20" title="Plan de Formación">📋</button>
                            </div>
                        </div>
                    </div>
                `;
            }).join('');
        }

        function actualizarStats() {
            const total = todosProyectos.length;
            const planificado = todosProyectos.filter(p => p.estado === 'Planificado').length;
            const desarrollo = todosProyectos.filter(p => p.estado === 'En desarrollo').length;
            const finalizado = todosProyectos.filter(p => p.estado === 'Finalizado').length;

            document.getElementById('statTotal').textContent = total;
            document.getElementById('statPlanificado').textContent = planificado;
            document.getElementById('statDesarrollo').textContent = desarrollo;
            document.getElementById('statFinalizado').textContent = finalizado;
        }

        function verProyecto(id) { window.location.href = `read.html?id=${id}`; }
        function verDocumentos(id) { window.location.href = `../documentos/i.html?project_id=${id}`; }
        function actualizarProyecto(id) { window.location.href = `edit.html?id=${id}`; }
        function crearPlanFormacion(id) { window.location.href = `../studyplan/index.html?project_id=${id}`; }
        function cerrarModal() { document.getElementById('modalDetalles').classList.add('hidden'); }

        // --- GESTIÓN DE PARTICIPANTES ---
        async function cargarUsuariosSistema() {
            try {
                const r = await fetch(`${API_URL}/users/`, { headers: { Authorization: 'Bearer ' + getToken() } });
                if (r.ok) {
                    usuariosSistema = await r.json();
                    const select = document.getElementById('partUsuarioSelect');
                    if (select) {
                        select.innerHTML = '<option value="">Seleccione un colaborador...</option>';
                        usuariosSistema.forEach(u => {
                            select.innerHTML += `<option value="${u.uid}">${u.nombre || u.email} (${u.email})</option>`;
                        });
                    }
                }
            } catch (e) {
                console.error('Error cargando usuarios del sistema:', e);
            }
        }

        async function gestionarParticipantes(projectId, projectName) {
            idProyectoParticipantesActivo = projectId;
            document.getElementById('participantesModalTitulo').textContent = `Participantes: ${projectName}`;
            document.getElementById('modalParticipantes').classList.remove('hidden');
            document.getElementById('modalParticipantes').classList.add('flex');
            
            document.getElementById('partUsuarioSelect').value = '';
            document.getElementById('partRolSelect').value = '6'; 

            cargarParticipantesProyecto(projectId);
        }

        function cerrarModalParticipantes() {
            document.getElementById('modalParticipantes').classList.add('hidden');
            document.getElementById('modalParticipantes').classList.remove('flex');
            idProyectoParticipantesActivo = null;
        }

        async function cargarParticipantesProyecto(projectId) {
            const tbody = document.getElementById('participantesTablaBody');
            tbody.innerHTML = `
                <tr>
                    <td colspan="3" class="p-4 text-center text-slate-400 text-sm">
                        <span class="inline-block animate-spin mr-2">🔄</span> Cargando participantes...
                    </td>
                </tr>
            `;

            try {
                const res = await fetch(`${API_URL}/participantes/${projectId}`, {
                    headers: { "Authorization": "Bearer " + getToken() }
                });
                if (!res.ok) throw new Error("Error al obtener participantes");
                const data = await res.json();

                if (data.length === 0) {
                    tbody.innerHTML = `
                        <tr>
                            <td colspan="3" class="p-6 text-center text-slate-500 text-sm">
                                No hay colaboradores asociados a este proyecto.
                            </td>
                        </tr>
                    `;
                    return;
                }

                tbody.innerHTML = data.map(p => {
                    const userObj = usuariosSistema.find(u => u.uid === p.user_uid);
                    const userName = userObj ? (userObj.nombre || userObj.email) : p.user_uid;
                    const userEmail = userObj ? `(${userObj.email})` : '';
                    const roleName = rolesMap[p.role_id] || `Rol ${p.role_id}`;

                    return `
                        <tr class="border-b border-white/5 hover:bg-white/5 text-sm text-slate-300">
                            <td class="p-4">
                                <div class="font-bold text-slate-200">${userName}</div>
                                <div class="text-[10px] text-slate-500 font-mono mt-0.5">${userEmail}</div>
                            </td>
                            <td class="p-4">
                                <span class="px-2.5 py-1 bg-purple-500/10 text-purple-300 text-xs font-semibold rounded-full border border-purple-500/20">${roleName}</span>
                            </td>
                            <td class="p-4 text-right">
                                <button onclick="eliminarColaboradorProyecto(${p.project_id}, '${p.user_uid}')" class="p-2 bg-rose-500/10 hover:bg-rose-500 hover:text-white text-rose-400 rounded-xl transition-all border border-rose-500/20" title="Eliminar del proyecto">
                                    <i class="fas fa-trash-alt"></i>
                                </button>
                            </td>
                        </tr>
                    `;
                }).join('');

            } catch (e) {
                tbody.innerHTML = `
                    <tr>
                        <td colspan="3" class="p-4 text-center text-rose-400 text-sm">
                            Error al cargar los participantes: ${e.message}
                        </td>
                    </tr>
                `;
            }
        }

        async function agregarColaboradorProyecto() {
            const userUid = document.getElementById('partUsuarioSelect').value;
            const roleId = document.getElementById('partRolSelect').value;

            if (!idProyectoParticipantesActivo) return;
            if (!userUid) {
                alert("Por favor, selecciona un colaborador de la lista.");
                return;
            }

            try {
                const res = await fetch(`${API_URL}/participantes/`, {
                    method: 'POST',
                    headers: { 
                        'Authorization': 'Bearer ' + getToken(),
                        'Content-Type': 'application/json' 
                    },
                    body: JSON.stringify({
                        project_id: parseInt(idProyectoParticipantesActivo),
                        user_uid: userUid,
                        role_id: parseInt(roleId)
                    })
                });

                if (!res.ok) {
                    const errData = await res.json();
                    throw new Error(errData.detail || "Error al asociar participante");
                }

                showSuccessMessage("¡Colaborador asociado exitosamente!");
                cargarParticipantesProyecto(idProyectoParticipantesActivo);
                document.getElementById('partUsuarioSelect').value = '';
            } catch (e) {
                alert("Error: " + e.message);
            }
        }

        async function eliminarColaboradorProyecto(projectId, userUid) {
            if (!confirm("¿Estás seguro de que deseas desvincular a este colaborador del proyecto?")) return;

            try {
                const res = await fetch(`${API_URL}/participantes/${projectId}/${userUid}`, {
                    method: 'DELETE',
                    headers: { 'Authorization': 'Bearer ' + getToken() }
                });

                if (!res.ok) {
                    const errData = await res.json();
                    throw new Error(errData.detail || "Error al eliminar participante");
                }

                showSuccessMessage("¡Colaborador desvinculado con éxito!");
                cargarParticipantesProyecto(projectId);
            } catch (e) {
                alert("Error: " + e.message);
            }
        }

        function exportarPDF() {
            const { jsPDF } = window.jspdf;
            const doc = new jsPDF();
            doc.setFontSize(20);
            doc.setTextColor(79, 70, 229);
            doc.text("Reporte General de Proyectos - VirtualMind", 14, 20);
            
            const data = todosProyectos.map(p => [
                p.id, p.name || 'N/A', clientesCache[p.client_id] || 'N/A', p.estado || 'N/A', p.start_date || '—'
            ]);

            doc.autoTable({
                head: [['ID', 'Proyecto', 'Cliente', 'Estado', 'Fecha Inicio']],
                body: data,
                startY: 30,
                theme: 'grid',
                headStyles: { fillColor: [79, 70, 229] }
            });
            doc.save(`VirtualMind_Proyectos_${new Date().toISOString().slice(0,10)}.pdf`);
        }

        // Escuchadores de Filtros del Dashboard
        document.getElementById('filtroEstado').addEventListener('change', renderProyectos);
        document.getElementById('filtroCliente').addEventListener('input', renderProyectos);
        document.getElementById('filtroNombre').addEventListener('input', renderProyectos);

        // --- SISTEMAS DE IA (GEMINI) ---
        async function generarNombreConIA() {
            const tipoProyecto = document.getElementById('tipoProyecto').value;
            const clienteSelect = document.getElementById('clienteSelect');
            const clienteNombre = clienteSelect.options[clienteSelect.selectedIndex]?.text || '';
            const descripcion = document.getElementById('description').value;

            if (!tipoProyecto && !descripcion) {
                alert('Por favor, selecciona un tipo de proyecto o escribe una descripción para que la IA genere un nombre.');
                return;
            }

            const btn = document.getElementById('btnGenerarNombreIA');
            const originalHTML = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

            const prompt = `Eres un experto en naming de proyectos educativos. Genera un nombre creativo y profesional para un proyecto educativo.${tipoProyecto ? `Tipo de proyecto: ${tipoProyecto}` : ''}${clienteNombre ? `Cliente: ${clienteNombre}` : ''}${descripcion ? `Descripción: ${descripcion}` : ''}Genera SOLO el nombre del proyecto, sin explicaciones ni comillas. El nombre debe ser corto (máximo 6 palabras) y descriptivo.`;
            try {
                const response = await fetch(API_GEMINI, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${getToken()}` },
                    body: JSON.stringify({ prompt })
                });

                if (!response.ok) throw new Error('Error al contactar la IA');
                const data = await response.json();
                const nombre = (data.respuesta || '').trim().replace(/^["']|["']$/g, '');
                if (nombre) document.getElementById('name').value = nombre;
            } catch (error) {
                alert('Error al generar nombre: ' + error.message);
            }
            btn.disabled = false;
            btn.innerHTML = originalHTML;
        }

        async function generarDescripcionConIA() {
            const nombre = document.getElementById('name').value;
            const tipoProyecto = document.getElementById('tipoProyecto').value;

            if (!nombre && !tipoProyecto) {
                alert('Por favor, escribe el nombre del proyecto o selecciona un tipo para generar la descripción.');
                return;
            }

            const btn = document.getElementById('btnGenerarDescIA');
            const originalHTML = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

            const prompt = `Eres un experto en redacción de proyectos educativos. Genera una descripción profesional y concisa (máximo 200 palabras) para un proyecto.${nombre ? `Nombre del proyecto: ${nombre}` : ''}${tipoProyecto ? `Tipo: ${tipoProyecto}` : ''}La descripción debe ser clara, atractiva y profesional.`;
            try {
                const response = await fetch(API_GEMINI, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${getToken()}` },
                    body: JSON.stringify({ prompt })
                });

                if (!response.ok) throw new Error('Error al contactar la IA');
                const data = await response.json();
                const descripcion = (data.respuesta || '').trim();
                if (descripcion) document.getElementById('description').value = descripcion;
            } catch (error) {
                alert('Error al generar descripción: ' + error.message);
            }
            btn.disabled = false;
            btn.innerHTML = originalHTML;
        }

        async function generarPublicoObjetivoConIA() {
            const nombre = document.getElementById('name').value;
            const descripcion = document.getElementById('description').value;
            const tipoProyecto = document.getElementById('tipoProyecto').value;

            if (!nombre && !descripcion && !tipoProyecto) {
                alert('Por favor, completa al menos el nombre o descripción del proyecto.');
                return;
            }

            const btn = document.getElementById('btnGenerarPublicoIA');
            const originalHTML = btn.innerHTML;
            btn.disabled = true;
            btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i>';

            const prompt = `Eres un experto en diseño instruccional. Basado en el siguiente proyecto educativo, indica qué público objetivo es el más apropiado. Selecciona de esta lista:- Primera infancia (0-5 años)- Niños 6 a 11 años- Adolescentes (12-17 años)- Jóvenes (18-25 años)- Adultos (26-59 años)- Mayores (60+)- Docentes / Educadores- Empresas / Equipos- Instituciones educativas- Público generalProyecto: ${nombre || 'Por definir'}Tipo: ${tipoProyecto || 'Por definir'}Descripción: ${descripcion || 'Por definir'}Responde SOLO con los nombres del público objetivo, uno por línea, sin números ni viñetas. Selecciona entre 1 y 3 opciones.`;
            const opcionesValidas = [
                'Primera infancia', 'Niños 6 a 11 años', 'Adolescentes', 'Jóvenes',
                'Adultos', 'Mayores', 'Docentes', 'Empresas', 'Instituciones educativas', 'Público general'
            ];
            try {
                const response = await fetch(API_GEMINI, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json', 'Authorization': `Bearer ${getToken()}` },
                    body: JSON.stringify({ prompt })
                });

                if (!response.ok) throw new Error('Error al contactar la IA');
                const data = await response.json();
                const respuesta = (data.respuesta || '').trim();
                const lineas = respuesta.split('\n').map(l => l.trim()).filter(l => l.length > 0);

                document.querySelectorAll('input[name="publico_objetivo"]').forEach(cb => { cb.checked = false; });
                lineas.forEach(linea => {
                    const limpio = linea.replace(/^[\d\.\)\-\*\•]+\s*/, '').trim();
                    opcionesValidas.forEach(opcion => {
                        if (limpio.toLowerCase().includes(opcion.toLowerCase()) || opcion.toLowerCase().includes(limpio.toLowerCase())) {
                            const cb = document.querySelector(`input[name="publico_objetivo"][value="${opcion}"]`);
                            if (cb) cb.checked = true;
                        }
                    });
                });
            } catch (error) {
                alert('Error al generar público objetivo: ' + error.message);
            }
            btn.disabled = false;
            btn.innerHTML = originalHTML;
        }

        // --- TUTORIAL INTERACTIVO INTEGRADO (DRIVER.JS) ---
        window.verTutorial = function(key) {
            if (key !== 'crear_proyecto') return;

            // Aseguramos que la vista activa sea el Formulario de Creación
            switchView('creacion');

            const driver = window.driver.js.driver;
            const tour = driver({
                showProgress: true,
                animate: true,
                nextBtnText: 'Siguiente &rarr;',
                prevBtnText: '&larr; Anterior',
                doneBtnText: '¡Entendido!',
                progressText: 'Paso {{current}} de {{total}}',
                popoverClass: 'driverjs-theme',
                steps: [
                    { 
                        element: '#btnTabDashboard', 
                        popover: { title: '📊 El Tablero', description: 'Aquí podrás ver el estado de todos tus proyectos, filtrar por cliente, actualizar datos y exportar reportes en PDF.', side: "bottom", align: 'center' } 
                    },
                    { 
                        element: '#name', 
                        popover: { title: 'Nombre del Proyecto', description: 'Ingresa un título claro. Recuerda que tienes botones al lado para <b>dictarlo con tu voz</b> (Whisper) o generarlo con <b>Inteligencia Artificial</b>.', side: "bottom", align: 'start' } 
                    },
                    { 
                        element: '#clienteSelect', 
                        popover: { title: 'Asignación de Cliente', description: 'Selecciona la empresa o usuario al que le pertenece este proyecto. Si vienes del módulo CRM, esto ya estará lleno.', side: "bottom", align: 'start' } 
                    },
                    { 
                        element: '#start_date', 
                        popover: { title: 'Cronograma', description: 'Fija al menos la fecha de inicio oficial. La fecha de finalización es opcional pero muy recomendada para las métricas.', side: "top", align: 'start' } 
                    },
                    { 
                        element: '#tipoProyecto', 
                        popover: { title: 'Tipo de Formación', description: '¿Es un curso virtual, un MOOC, un Podcast? Selecciona la categoría principal de desarrollo.', side: "bottom", align: 'start' } 
                    },
                    { 
                        element: '#description', 
                        popover: { title: 'Descripción', description: 'Escribe un resumen del alcance. ¡Nuestra IA puede redactarlo por ti automáticamente si se lo pides!', side: "top", align: 'start' } 
                    },
                    { 
                        element: '#submitButton', 
                        popover: { title: '¡Todo listo!', description: 'Haz clic aquí para crear y guardar. Una vez procesado, el sistema te redirigirá a armar el Plan de Estudios a detalle.', side: "top", align: 'center' } 
                    }
                ]
            });                        
            tour.drive();
        };

        // Lógica Mostrar/Ocultar "Otros" Inputs
        function setupToggleOtro(selectId, inputId) {
            const sel = document.getElementById(selectId);
            const inp = document.getElementById(inputId);
            if (!sel || !inp) return;
            const apply = () => {
                if (sel.value === 'Otro') {
                    inp.classList.remove('hidden');
                    inp.disabled = false;
                    inp.required = true;
                } else {
                    inp.classList.add('hidden');
                    inp.disabled = true;
                    inp.required = false;
                    inp.value = '';
                }
            };
            sel.addEventListener('change', apply);
            apply();
        }

        function setupLenguajeInclusivo() {
            const incl1 = document.getElementById('incluyenteSi');
            const incl0 = document.getElementById('incluyenteNo');
            const tipoLenguaje = document.getElementById('tipoLenguajeSelect');
            const otroLenguaje = document.getElementById('otroLenguajeInput');
            const micOtro = document.getElementById('btn-mic-otroLenguajeInput');
            if (!incl1 || !incl0 || !tipoLenguaje || !otroLenguaje) return;
            incl1.addEventListener('change', () => { tipoLenguaje.disabled = false; });
            incl0.addEventListener('change', () => { 
                tipoLenguaje.disabled = true; 
                tipoLenguaje.value = ''; 
                otroLenguaje.disabled = true; 
                otroLenguaje.value = ''; 
                if (micOtro) {
                    micOtro.disabled = true;
                    micOtro.setAttribute('disabled', 'disabled');
                }
            });
            tipoLenguaje.addEventListener('change', () => {
                const acts = tipoLenguaje.value === 'Otro';
                otroLenguaje.disabled = !acts;
                if (micOtro) {
                    if (!acts) {
                        micOtro.setAttribute('disabled', 'disabled');
                        micOtro.disabled = true;
                    } else {
                        micOtro.removeAttribute('disabled');
                        micOtro.disabled = false;
                    }
                }
                if (!acts) otroLenguaje.value = '';
            });
        }

        function setupInclusionDigital() {
            const inclSi = document.getElementById('inclusionSi');
            const inclNo = document.getElementById('inclusionNo');
            const checkboxes = document.querySelectorAll('input[name^="inclusion_digital_"]');
            const otroInput = document.querySelector('input[name="inclusion_digital_otro"]');
            const micOtro = document.getElementById('btn-mic-inclusion_digital_otro');
            if (!inclSi || !inclNo) return;
            function setEnabled(enabled) {
                checkboxes.forEach(ch => { ch.disabled = !enabled; if (!enabled) ch.checked = false; });
                if (otroInput) { 
                    otroInput.disabled = !enabled; 
                    if (!enabled) otroInput.value = ''; 
                }
                if (micOtro) {
                    if (!enabled) {
                        micOtro.setAttribute('disabled', 'disabled');
                        micOtro.disabled = true;
                    } else {
                        micOtro.removeAttribute('disabled');
                        micOtro.disabled = false;
                    }
                }
            }
            inclSi.addEventListener('change', () => setEnabled(true));
            inclNo.addEventListener('change', () => setEnabled(false));
            setEnabled(inclSi.checked);
        }

        // --- SUBMIT DE CREACIÓN AL SERVIDOR ---
        document.getElementById('formProyecto').addEventListener('submit', async e => {
            e.preventDefault();
            const token = getToken();
            if (!token) return;

            const submitButton = document.getElementById('submitButton');
            const mensajeDiv = document.getElementById('form-message');
            submitButton.disabled = true;
            document.getElementById('submitButtonText').textContent = "⏳ Creando Proyecto...";
            mensajeDiv.innerHTML = "";

            const f = e.target;
            const lenguajeIncl = getRadioValue(f, 'lenguaje_incluyente') === 'true';
            const inclusionDig = getRadioValue(f, 'inclusion_digital') === 'true';
            const publico = Array.from(f.querySelectorAll('input[name="publico_objetivo"]:checked')).map(c => c.value);                  
            const tipoLenguajeSelect = document.getElementById('tipoLenguajeSelect');
            const otroLenguajeInput = document.getElementById('otroLenguajeInput');
            const tipoLeng = lenguajeIncl ? (tipoLenguajeSelect?.value || null) : null;
            const tipoLengOtro = lenguajeIncl && tipoLeng === 'Otro' ? (otroLenguajeInput?.value || null) : null;

            function getSelectConOtro(selectId, inputId) {
                const sel = document.getElementById(selectId);
                const inp = document.getElementById(inputId);
                if (!sel) return null;
                if (sel.value === 'Otro') return inp?.value || null;
                return sel.value || null;
            }

            const data = {
                name: f.name.value,
                client_id: document.getElementById('clientId').value,
                codigo_referencia: document.getElementById('codigoReferencia').value,
                start_date: f.start_date.value,
                end_date: f.end_date.value || null,
                tipo_proyecto: f.tipo_proyecto.value,
                tipo_proyecto_personalizado: f.tipo_proyecto.value === 'Otro' ? (f.tipo_proyecto_personalizado.value || null) : null,
                estado: f.estado.value,
                description: f.description.value || null,
                lenguaje_incluyente: lenguajeIncl,
                lenguaje_inclusivo_tipo: tipoLeng,
                lenguaje_inclusivo_otro: tipoLengOtro,
                inclusion_digital: inclusionDig,
                inclusion_digital_web: getCheckboxValue(f, 'inclusion_digital_web'),
                inclusion_digital_asistiva: getCheckboxValue(f, 'inclusion_digital_asistiva'),
                inclusion_digital_universal: getCheckboxValue(f, 'inclusion_digital_universal'),
                inclusion_digital_educativa: getCheckboxValue(f, 'inclusion_digital_educativa'),
                inclusion_digital_otro: f['inclusion_digital_otro']?.value || null,
                idioma: getRadioValue(f, 'idioma'),
                idioma_otro: f['idioma_otro']?.value || null,
                tipografia_titulo_fuente: getSelectConOtro('tituloFuente', 'tituloFuenteOtro'),
                tipografia_titulo_tamano: getSelectConOtro('tituloTamano', 'tituloTamanoOtro'),
                tipografia_titulo_negrita: getCheckboxValue(f, 'tipografia_titulo_negrita'),
                tipografia_titulo_cursiva: getCheckboxValue(f, 'tipografia_titulo_cursiva'),
                tipografia_subtitulo_fuente: getSelectConOtro('subtituloFuente', 'subtituloFuenteOtro'),
                tipografia_subtitulo_tamano: getSelectConOtro('subtituloTamano', 'subtituloTamanoOtro'),
                tipografia_subtitulo_negrita: getCheckboxValue(f, 'tipografia_subtitulo_negrita'),
                tipografia_subtitulo_cursiva: getCheckboxValue(f, 'tipografia_subtitulo_cursiva'),
                tipografia_parrafo_fuente: getSelectConOtro('parrafoFuente', 'parrafoFuenteOtro'),
                tipografia_parrafo_tamano: getSelectConOtro('parrafoTamano', 'parrafoTamanoOtro'),
                tipografia_parrafo_negrita: getCheckboxValue(f, 'tipografia_parrafo_negrita'),
                tipografia_parrafo_cursiva: getCheckboxValue(f, 'tipografia_parrafo_cursiva'),
                horas_curso: f.horas_curso.value ? parseFloat(f.horas_curso.value) : null,
                horas_aprendizaje_autonomo_virtual: f.horas_aprendizaje_autonomo_virtual.value ? parseFloat(f.horas_aprendizaje_autonomo_virtual.value) : null,
                horas_actividades_aprendizaje: f.horas_actividades_aprendizaje.value ? parseFloat(f.horas_actividades_aprendizaje.value) : null,
                cesion_derechos: getRadioValue(f, 'cesion_derechos') === 'true',
                derechos_patrimoniales_autor: getRadioValue(f, 'derechos_patrimoniales_autor') === 'true',
                acuerdo_confidencialidad: getRadioValue(f, 'acuerdo_confidencialidad') === 'true',
                entrega_fuentes: getRadioValue(f, 'entrega_fuentes') === 'true',
                entrega_escrito_autor: getRadioValue(f, 'entrega_escrito_autor') === 'true',
                entrega_diseno_instruccional: getRadioValue(f, 'entrega_diseno_instruccional') === 'true',
                publico_objetivo: publico,
                publico_objetivo_otro: f['publico_objetivo_otro']?.value || null,
                observaciones: f.observaciones?.value || null
            };

            try {
                const res = await fetch(`${API_URL}/projects/`, {
                    method: 'POST',
                    headers: { 'Authorization': 'Bearer ' + token, 'Content-Type': 'application/json' },
                    body: JSON.stringify(data)
                });

                if (!res.ok) {
                    const errorData = await res.json();
                    throw new Error(errorData.detail || `Error ${res.status}`);
                }

                const proyecto = await res.json();
                const project_id = proyecto.id;
                const project_name = encodeURIComponent(data.name || '');
                const project_desc = encodeURIComponent(data.description || '');
                const project_horas = data.horas_curso || '';

                mensajeDiv.innerHTML = `<p class="text-lg font-semibold text-emerald-400">✅ Proyecto creado con éxito (ID: ${project_id}). Redirigiendo a planificación...</p>`;
                const urlHijo = "https://gestordecursos.pegui.edu.co/r/superadmin/studyplan/";
                setTimeout(() => {
                    window.location.href = `${urlHijo}?project_id=${project_id}&project_name=${project_name}&project_desc=${project_desc}&project_horas=${project_horas}`;
                }, 2000);

            } catch (err) {
                console.error('Error al crear proyecto:', err);
                mensajeDiv.innerHTML = `<p class="text-rose-500 font-semibold mb-2">❌ Error: ${err.message}</p>`;
                submitButton.disabled = false;
                document.getElementById('submitButtonText').textContent = '💾 Crear Proyecto';
            }
        });

        // --- CONFIGURACIÓN DE LENGUAJE NOTIFICACIONES ---
        function showNotification(type, message) {
            const container = document.getElementById('customToastContainer');
            if (!container) return;
            const toast = document.createElement('div');
            toast.className = `flex items-center p-3 rounded-xl shadow-xl border backdrop-blur-md transform translate-y-2 opacity-0 transition-all duration-300 pointer-events-auto ${
                type === 'success' 
                    ? 'bg-emerald-950/90 border-emerald-500/30 text-emerald-200' 
                    : 'bg-rose-950/90 border-rose-500/30 text-rose-200'
            }`;
            toast.innerHTML = `
                <span class="mr-2 text-lg">${type === 'success' ? '✨' : '⚠️'}</span>
                <div class="text-xs font-semibold tracking-wide">${message}</div>
            `;
            container.appendChild(toast);
            setTimeout(() => {
                toast.classList.remove('translate-y-2', 'opacity-0');
            }, 50);
            setTimeout(() => {
                toast.classList.add('opacity-0', 'translate-y-2');
                setTimeout(() => toast.remove(), 300);
            }, 4000);
        }
        
        window.alert = function(msg) {
            const isSuccess = msg.includes('✅') || msg.toLowerCase().includes('éxito') || msg.toLowerCase().includes('copiado');
            showNotification(isSuccess ? 'success' : 'error', msg.replace(/[✅❌]/g, '').trim());
        };

        function showSuccessMessage(message) {
            showNotification('success', message);
        }

        // --- CARGAR CLIENTES DE LA API ---
        async function loadClients() {
            try {
                const r = await fetch(`${API_URL}/users/`, { headers: { Authorization: 'Bearer ' + getToken() } });
                if (!r.ok) return [];
                const users = await r.json();
                return users.filter(u => Array.isArray(u.roles) && u.roles.includes('cliente') && u.estado);
            } catch (e) {
                console.error('Error cargando clientes:', e);
                return [];
            }
        }

        function populateClientSelect(clientes) {
            const sel = document.getElementById('clienteSelect');
            if (!sel) return;
            sel.innerHTML = '<option value="">Seleccione un cliente…</option>';
            clientes.forEach(c => {
                sel.innerHTML += `<option value="${c.uid}">${c.nombre || c.name} (${c.email})</option>`;
            });
            sel.addEventListener('change', e => {
                document.getElementById('clientId').value = e.target.value;
                document.getElementById('codigoReferencia').value = generarCodigoReferencia(12);
            });
        }

        function generarCodigoReferencia(length = 12) {
            const array = new Uint8Array(length / 2);
            crypto.getRandomValues(array);
            return Array.from(array, b => b.toString(16).padStart(2, "0")).join("");
        }

        // ==================== INICIALIZACIÓN PRINCIPAL ====================
        window.addEventListener('DOMContentLoaded', async () => {
            const token = getToken();
            if (!token) {
                window.location.href = '/';
                return;
            }
                        
            // Iniciar V1 (Dashboard)
            cargarProyectos();
            
            // Cargar lista general de usuarios para participantes
            await cargarUsuariosSistema();

            // Iniciar V2 (Formulario)
            const clientes = await loadClients();
            populateClientSelect(clientes);

            const today = new Date().toISOString().split('T')[0];
            document.getElementById('start_date').min = today;
            document.getElementById('start_date').value = today;

            const urlParams = new URLSearchParams(window.location.search);
            const clientIdFromUrl = urlParams.get('clientId');
            const clientNameFromUrl = decodeURIComponent(urlParams.get('clientName') || '');

            if (clientIdFromUrl) {
                const clienteSelect = document.getElementById('clienteSelect');
                const clientIdInput = document.getElementById('clientId');
                if (clientNameFromUrl && !clienteSelect.querySelector(`option[value="${clientIdFromUrl}"]`)) {
                    const newOption = new Option(`${clientNameFromUrl} (ID: ${clientIdFromUrl})`, clientIdFromUrl, true, true);
                    clienteSelect.appendChild(newOption);
                }
                clienteSelect.value = clientIdFromUrl;
                if (clientIdInput) clientIdInput.value = clientIdFromUrl;
                document.getElementById('codigoReferencia').value = generarCodigoReferencia(12);
                clienteSelect.disabled = true;
                clienteSelect.classList.add("bg-slate-950/60", "text-slate-400", "cursor-not-allowed");
                
                // Si viene del CRM, saltar directo al formulario
                switchView('creacion');
            }

            setupLenguajeInclusivo();
            setupInclusionDigital();

            const estadoSelect = document.getElementById('estado');
            const estadoWarning = document.getElementById('estadoWarning');
            if (estadoSelect && estadoWarning) {
                estadoSelect.addEventListener('change', function() {
                    const warns = ['En desarrollo', 'Aprobado', 'Finalizado'];
                    estadoWarning.classList.toggle('hidden', !warns.includes(this.value));
                });
            }
            setupToggleOtro('tipoProyecto', 'tipoProyectoPersonalizado');
            setupToggleOtro('tituloFuente', 'tituloFuenteOtro');
            setupToggleOtro('tituloTamano', 'tituloTamanoOtro');
            setupToggleOtro('subtituloFuente', 'subtituloFuenteOtro');
            setupToggleOtro('subtituloTamano', 'subtituloTamanoOtro');
            setupToggleOtro('parrafoFuente', 'parrafoFuenteOtro');
            setupToggleOtro('parrafoTamano', 'parrafoTamanoOtro');

            resetearIconosMic();
        });
    </script>
    <script src="/js/roles.js"></script>
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const token = localStorage.getItem('token');
            if (!token) return;

            try {
                const payload = JSON.parse(atob(token.split('.')[1]));
                const permissions = payload.permissions || [];
                const hasAnyPermission = (perms) => perms.some(p => permissions.includes(p));

                const menuPermissions = {
                    'menu-proyectos': ['proyectos_crear', 'proyectos_consultar'],
                    'menu-crear-proyecto': ['proyectos_crear'],
                    'menu-ia': ['ia_produccion_imagen', 'ia_linguistica_usar'],
                    'menu-drive': ['archivos_drive_personal_ver', 'archivos_drive_global_ver'],
                    'menu-entidades': ['autor_crear', 'diseno_instruccional_crear'],
                    'menu-plan-estudio': ['proyectos_planes_formacion_listar', 'diseno_instruccional_ver'],
                    'menu-evaluaciones': ['proyectos_evaluaciones_listar'],
                };
                                
                Object.entries(menuPermissions).forEach(([id, required]) => {
                    const el = document.getElementById(id);
                    if (el && !hasAnyPermission(required)) el.style.display = 'none';
                });
            } catch(e) {
                console.error("Error validando token/roles: ", e);
            }
        });
    </script>

    <!-- Tooltips Dinámicos Estables -->
    <script>
        (function(){
            if(window.__ttLoaded) return;
            window.__ttLoaded=true;
            let el=null;
            document.addEventListener('mouseover',function(e){
                var t=e.target.closest('[data-tooltip]');
                if(!t)return;
                var txt=t.getAttribute('data-tooltip');
                if(!txt)return;
                if(el)el.remove();
                el=document.createElement('div');
                el.className='vm-tooltip';
                el.textContent=txt;
                document.body.appendChild(el);
                var r=t.getBoundingClientRect(),pos=t.getAttribute('data-tooltip-position')||'top';
                requestAnimationFrame(function(){
                    if(!el)return;
                    var tr=el.getBoundingClientRect(),top=0,left=0;
                    if(pos==='top'){
                        top=r.top+window.scrollY-tr.height-8;
                        left=r.left+window.scrollX+(r.width/2)-(tr.width/2);
                    }else if(pos==='bottom'){
                        top=r.bottom+window.scrollY+8;
                        left=r.left+window.scrollX+(r.width/2)-(tr.width/2);
                    }else if(pos==='left'){
                        top=r.top+window.scrollY+(r.height/2)-(tr.height/2);
                        left=r.left+window.scrollX-tr.width-8;
                    }else if(pos==='right'){
                        top=r.top+window.scrollY+(r.height/2)-(r.height/2);
                        left=r.right+window.scrollX+8;
                    }
                    if(left<5)left=5;
                    if(left+tr.width>window.innerWidth-5)left=window.innerWidth-tr.width-5;
                    el.style.top=top+'px';
                    el.style.left=left+'px';
                    el.classList.add('visible');
                });
            });
            document.addEventListener('mouseout',function(e){
                if(e.target.closest('[data-tooltip]')&&el){
                    el.classList.remove('visible');
                    setTimeout(function(){if(el){el.remove();el=null}},150);
                }
            });
        })();
    </script>
</body>
</html>
