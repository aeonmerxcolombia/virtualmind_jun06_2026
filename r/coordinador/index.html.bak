          { label: 'Canvas', permission: 'herramientas_canvas_usar', url: 'canvas/index.html' },
          { label: 'Crear Animación 3D', permission: 'ia_animacion_3d_crear', url: 'animaciones3d/index.html' },
          { label: 'Office', permission: 'herramientas_Office_usar', url: 'documentos/index.html' },
          { label: '📚 Biblioteca de Documentos', permission: 'recursos_biblioteca_ver', url: 'biblioteca/index.html' },
          { label: '🎬 Editor de Contenido', permission: 'contenido_editar', url: 'https://gestordecursos.pegui.edu.co/editor/' }
        ]
      },
      'adminSeguridad': {
        label: 'Administración y seguridad',
        icon: '🔒',
        items: [
          { label: 'Auditoría de Usuarios', permission: 'seguridad_auditoria_ver', url: 'auditoria.html' },
          { label: 'Firma Digital de Documentos', permission: 'seguridad_firma_digital', url: 'firmadigital' },
          { label: 'Bitácora de Actividad por usuarios', permission: 'seguridad_bitacora_usuarios_ver', url: 'bitacora' },
          { label: 'Bloqueo de Edición por Fase Finalizada', permission: 'seguridad_bloqueo_edicion_fase', url: 'bloqueodefases' }
        ]
      },
// --- ⚙️ NUEVA SECCIÓN: CONFIGURACIÓN ---
      'configuracion': {
        label: 'Configuración',
        icon: '⚙️',
        items: [
          { label: 'Variables Globales (Email)', permission: 'config_global_ver', url: 'admin_config.html' },
          { label: 'Gestor de Tareas IA', permission: 'config_global_ver', url: 'tareas-ia.html' }
        ]
      },
      'reportes': {
        label: 'Reportes',
        icon: '📊',
        items: [
          { label: 'Estadísticas', permission: 'reportes_estadisticas_ver', url: 'estadisticas/' },
          { label: 'Cambiar Fondo del Login', permission: 'reportes_fondo_login_cambiar', url: 'cambiarfondo/' },
          { label: 'Panel de seguimiento y métricas', permission: 'reportes_metricas_ver', url: 'metricas' }
        ]
      },
      'zona_capacitacion': {
        label: 'Zona de Capacitación',
        icon: '📚',
        items: [
          { label: 'Microcursos sobre la plataforma', permission: 'capacitacion_microcursos_ver', url: 'microcursos' },
          { label: 'Buenas prácticas por perfil', permission: 'capacitacion_buenas_practicas_ver', url: 'mejorespracticas' },
          { label: 'Tutoriales en Video', permission: 'capacitacion_tutoriales_ver', url: 'tutorialesvideo' },
          { label: 'Preguntas Frecuentes (FAQ)', permission: 'capacitacion_faq_ver', url: 'faq' }
        ]
      },
      'diseño_y_autores': {
