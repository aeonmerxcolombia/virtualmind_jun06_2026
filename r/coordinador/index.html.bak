        icon: '✍️',
        items: [
          { label: 'Crear Autor', permission: 'autor_crear', url: 'autorcontenido/create.html' },
          { label: 'Ver Autores', permission: 'autor_ver', url: 'autorcontenido/' },
          { label: 'Crear Diseño Instruccional', permission: 'diseno_instruccional_crear', url: 'disenoinstruccional/create.html' },
          { label: 'Ver Diseños Instruccionales', permission: 'diseno_instruccional_ver', url: 'disenoinstruccional/' }
        ]
      }
      // 'crm' duplicado eliminado
    };
    
    // (Resto de tu JavaScript sin cambios)
    function parseJwt(token) { /* ... */ try { const base64Url = token.split('.')[1]; const base64 = base64Url.replace(/-/g, '+').replace(/_/g, '/'); const jsonPayload = decodeURIComponent( atob(base64) .split('') .map(c => '%' + ('00' + c.charCodeAt(0).toString(16)).slice(-2)) .join('') ); return JSON.parse(jsonPayload); } catch (e) { console.error("Error decodificando token:", e); return null; } }
    async function fetchPermissionsForCurrentRole() { if (!token) { return new Set(); } const path = window.location.pathname; const currentRole = path.split('/')[2]; if (!currentRole || currentRole === 'superadmin') { return new Set(); } try { const res = await fetch(`${API}/roles/`, { headers: { 'Authorization': `Bearer ${token}` } }); if (!res.ok) { if (res.status === 401) { logout(); } throw new Error(`HTTP error! status: ${res.status}`); } const allRoles = await res.json(); const currentRoleObject = allRoles.find(r => r.name === currentRole); if (currentRoleObject && currentRoleObject.permissions) { return new Set(currentRoleObject.permissions.map(p => p.name)); } return new Set(); } catch (error) { console.error(`Error consultando permisos para el rol '${currentRole}':`, error); return new Set(); } }
    async function renderSidebar() { const sidebarMenu = document.getElementById('dynamic-sidebar-menu'); if (!sidebarMenu) return; sidebarMenu.innerHTML = ''; const path = window.location.pathname; const currentRole = path.split('/')[2]; let permissionsToRender = new Set(); if (currentRole === 'superadmin') { for (const sectionId in menuMapping) { menuMapping[sectionId].items.forEach(item => permissionsToRender.add(item.permission) ); } } else { permissionsToRender = await fetchPermissionsForCurrentRole(); } for (const sectionId in menuMapping) { const section = menuMapping[sectionId]; const visibleItems = section.items.filter(item => permissionsToRender.has(item.permission) ); if (visibleItems.length > 0) { let sectionItemsHTML = visibleItems.map(item => `<a href="#" onclick="selectMenu(this); cargarVista('${item.url}')" class="menu-item block text-gray-200 hover:text-indigo-300 py-1">${item.label}</a>` ).join(''); sidebarMenu.innerHTML += ` <div class="menu-container"> <button onclick="toggleMenu('${sectionId}')" class="flex items-center w-full text-white py-2 px-3 rounded hover:bg-[#282c37] transition"> <span class="mr-3">${section.icon}</span> <span class="flex-1 text-left font-semibold">${section.label}</span> <svg id="icon-${sectionId}" class="w-4 h-4 ml-auto transition-transform" fill="none" stroke="white" stroke-width="3" viewBox="0 0 24 24"><path d="M6 9l6 6 6-6"/></svg> </button> <div id="${sectionId}" class="ml-9 mt-1 space-y-1 hidden"> ${sectionItemsHTML} </div> </div> `; } } }
    async function cargarPerfilSidebar() { if (!token) return; const payload = parseJwt(token); if (!payload || !payload.user_id) { logout(); return; } const user_id = payload.user_id; localStorage.setItem("user_id", user_id); try { const res = await fetch(`${API}/users/${user_id}`, { headers: { Authorization: "Bearer " + token } }); const data = await res.json(); const roles = data.roles; const sel = document.getElementById("roleSelect"); sel.innerHTML = ""; const path = window.location.pathname; const currentRole = path.split('/')[2]; roles.forEach(r => { const o = document.createElement("option"); o.value = r; o.textContent = r.charAt(0).toUpperCase() + r.slice(1); if (r === currentRole) o.selected = true; sel.appendChild(o); }); sel.addEventListener("change", () => sel.value && (window.location.href = `/r/${sel.value}/`)); } catch (e) { console.error("Error cargando roles de usuario:", e); } try { const res2 = await fetch(`${API}/profiles/${user_id}`, { headers: { Authorization: "Bearer " + token } }); const p = await res2.json(); document.getElementById("sidebarAvatar").src = p.foto_url || "/assets/default_avatar.png"; document.getElementById("sidebarName").textContent = p.nombre || "Perfil"; } catch (e) { console.error("Error cargando perfil:", e); } }
    async function cargarNotificaciones() { try { const res = await fetch(`${API}/notifications/`, { headers: { Authorization: "Bearer " + token } }); if (res.status === 401) { logout(); return; } const data = await res.json(); const user_id = localStorage.getItem("user_id"); const notifs = (data.notificaciones || []).filter(n => String(n.usuario_id) === String(user_id)); notifList.innerHTML = ""; if (notifs.length === 0) { notifCount.textContent = 0; notifEmpty.style.display = "block"; return; } notifCount.textContent = notifs.length; notifEmpty.style.display = "none"; notifs.forEach(n => { const div = document.createElement("div"); div.className = "px-4 py-2 hover:bg-gray-100 cursor-pointer text-sm"; div.textContent = `${n.descripcion} • ${new Date(n.fecha).toLocaleString()}`; notifList.appendChild(div); }); } catch (err) { console.error("Error al cargar notificaciones:", err); } }
    
    // --- CAMBIO 2: Lógica para resaltar el menú por defecto ---
    
    /**
     * Busca un ítem del menú por su texto.
     */
    function findMenuItemByText(text) {
      const menuItems = document.querySelectorAll('.menu-item');
      for (const item of menuItems) {
        if (item.textContent.trim() === text) {
          return item;
        }
      }
      return null;
    }
    
    /**
     * Resalta el ítem por defecto "Crear Cliente (CRM)" y expande su sección.
     */
    function highlightDefaultMenuItem() {
      const defaultMenuItem = findMenuItemByText('Crear Cliente (CRM)');
      if (defaultMenuItem) {
        // 1. Resaltar el ítem
        selectMenu(defaultMenuItem);
        
        // 2. Expandir su sección padre ("Proyectos") si está colapsada
        const parentContainer = defaultMenuItem.closest('.menu-container');
        if (parentContainer) {
          const toggleButton = parentContainer.querySelector('button[onclick^="toggleMenu"]');
          const menuContent = parentContainer.querySelector('.space-y-1'); // El div que se oculta
          
          // Si el contenido está oculto, haz clic en el botón para expandirlo
          if (toggleButton && menuContent && menuContent.classList.contains('hidden')) {
            toggleButton.click();
          }
        }
      }
    }

    (async () => {
      await cargarPerfilSidebar();
      await renderSidebar();
      await cargarNotificaciones();
      setInterval(cargarNotificaciones, 30000);
      
      // --- CAMBIO 2 (continuación): Llamar a la función después de renderizar el menú ---
      highlightDefaultMenuItem();
    })();
    // --- FIN DEL CAMBIO 2 ---

    async function verMiPerfil() {
      const token = localStorage.getItem("token");
      if (!token) { alert("No hay sesión iniciada"); return; }
      
      let user_id = localStorage.getItem("user_id");
      
      if (!user_id) {
        try {
          const payload = JSON.parse(atob(token.split('.')[1]));
          user_id = payload.user_id;
        } catch (e) {
          console.error("Error decodificando token:", e);
        }
      }
      
      const path = window.location.pathname;
      const currentRole = path.split('/')[2] || 'superadmin';
      
      if (user_id) {
        window.location.href = `/r/${currentRole}/perfil/index.html?user_id=${user_id}`;
      } else {
        alert("No se pudo obtener el ID de usuario");
      }
    }
    const chatWidget = document.getElementById('chatWidget'); /* ... (resto del código del chat) ... */
    const chatWidgetToggle = document.getElementById('chatWidgetToggle'); const chatBox = document.getElementById("chatBoxWidget"); const KEY = "chat_historial"; chatWidgetToggle.addEventListener('click', () => { chatWidget.classList.toggle('opened'); if (chatWidget.classList.contains('opened')) { chatBox.scrollTop = chatBox.scrollHeight; } }); window.addEventListener("DOMContentLoaded", () => { chatBox.innerHTML = localStorage.getItem(KEY) || `<div class="chat-bubble bg-white p-3 rounded-lg shadow text-sm text-gray-600">💬 Hola, ¿en qué puedo ayudarte hoy?</div>`; chatBox.scrollTop = chatBox.scrollHeight; }); function convertMarkdownToHtml(text) { let htmlText = text.replace(/\*\*(.*?)\*\*/g, '<strong>$1</strong>'); htmlText = htmlText.replace(/\*(.*?)\*/g, '<strong>$1</strong>'); htmlText = htmlText.replace(/\n/g, '<br>'); return htmlText; } function appendBubble(originalTxt, who = "IA") { const d = document.createElement("div"); d.className = who === "Tú" ? "chat-bubble bg-indigo-100 p-3 rounded-lg text-sm text-gray-800" : "chat-bubble bg-white p-3 rounded-lg shadow text-sm text-gray-800 relative"; const id = `respuesta-${Date.now()}`; const textoParaMostrar = convertMarkdownToHtml(originalTxt); const contenido = `<strong>${who}:</strong> <span id="${id}">${textoParaMostrar}</span>`; d.innerHTML = contenido; if (who === "IA") { const btnCopy = document.createElement("button"); btnCopy.textContent = "📋 Copiar"; btnCopy.title = "Copiar al portapapeles"; btnCopy.className = "ml-2 text-xs text-indigo-600 hover:underline"; btnCopy.onclick = () => copiarTexto(id); const btnSpeak = document.createElement("button"); btnSpeak.innerHTML = "🔊 Escuchar"; btnSpeak.title = "Escuchar esta respuesta"; btnSpeak.className = "ml-2 text-xs text-indigo-600 hover:underline"; btnSpeak.onclick = () => speakText(originalTxt, btnSpeak); const buttonsContainer = document.createElement("div"); buttonsContainer.className = "mt-1 flex"; buttonsContainer.appendChild(btnCopy); buttonsContainer.appendChild(btnSpeak); d.appendChild(buttonsContainer); } chatBox.appendChild(d); chatBox.scrollTop = chatBox.scrollHeight; const copia = chatBox.cloneNode(true); copia.querySelectorAll("button").forEach(b => b.remove()); localStorage.setItem(KEY, copia.innerHTML); }
    async function enviarMensaje() { const msg = document.getElementById("chatInput").value.trim(); if (!msg) return; appendBubble(msg, "Tú"); document.getElementById("chatInput").value = ""; const t = document.createElement("div"); t.id = "typing"; t.className = "chat-bubble bg-gray-100 p-3 rounded-lg italic text-gray-500"; t.innerText = "💬 IA está escribiendo..."; chatBox.appendChild(t); chatBox.scrollTop = chatBox.scrollHeight; const mdl = "gemini"; try { const r = await fetch(`${API}/chat/${mdl}`, { method: "POST", headers: { "Content-Type": "application/json", "Authorization": `Bearer ${token}` }, body: JSON.stringify({ prompt: msg }) }); const { respuesta } = await r.json(); appendBubble(respuesta, "IA"); } catch { appendBubble("❌ Error al contactar IA.", "IA"); } finally { document.getElementById("typing")?.remove(); } }
    const toggleBtn = document.getElementById('accessibilityToggle'); const panel = document.getElementById('accessibilityControls'); const wrap = document.getElementById('accessibilityMenu');
    toggleBtn.addEventListener('click', function(e) { e.stopPropagation(); panel.classList.toggle('visible'); });
    window.addEventListener('click', function(e) { if (panel.classList.contains('visible') && !wrap.contains(e.target)) { panel.classList.remove('visible'); } });
    const mainFrame = document.getElementById('mainFrame');
    if (mainFrame) { mainFrame.addEventListener('load', function() { try { mainFrame.contentWindow.addEventListener('click', function() { panel.classList.remove('visible'); }); } catch(e) {} }); }
    panel.querySelectorAll('input[type="checkbox"][data-act]').forEach(b => { b.addEventListener('change', () => document.body.classList.toggle(b.getAttribute('data-act')) ); });
    const screenReaderToggle = document.getElementById('screenReaderToggle');
    let screenReaderActive = false;
    let lastHoveredElement = null;
    let hoverTimeout = null;
    function speakTextSR(text) { if ('speechSynthesis' in window) { speechSynthesis.cancel(); const utterance = new SpeechSynthesisUtterance(text); utterance.rate = 1.2; utterance.pitch = 1; setTimeout(() => speechSynthesis.speak(utterance), 100); } }
    function getReadableText(el) { let text = el.innerText || el.textContent || ''; if (!text || text.trim().length < 2) { const img = el.querySelector('img'); if (img) text = img.alt || ''; if (!text) { const input = el.querySelector('input, select, textarea'); if (input) text = input.placeholder || input.value || input.type || ''; } } return text.trim().substring(0, 200); }
    function activateScreenReader() { screenReaderActive = true; document.body.classList.add('screen-reader'); speakTextSR('Lector de pantalla activado. Pase el cursor sobre los elementos para escucharlos.'); document.querySelectorAll('a, button, input, select, textarea, h1, h2, h3, h4, h5, h6, p, span, div, img, li, td, th, label').forEach(el => { el.addEventListener('mouseenter', handleHover); el.addEventListener('mouseleave', () => { if (hoverTimeout) clearTimeout(hoverTimeout); }); }); }
    function deactivateScreenReader() { screenReaderActive = false; document.body.classList.remove('screen-reader'); speakTextSR('Lector de pantalla desactivado.'); document.querySelectorAll('a, button, input, select, textarea, h1, h2, h3, h4, h5, h6, p, span, div, img, li, td, th, label').forEach(el => { el.removeEventListener('mouseenter', handleHover); }); if ('speechSynthesis' in window) speechSynthesis.cancel(); }
    function handleHover(e) { if (hoverTimeout) clearTimeout(hoverTimeout); hoverTimeout = setTimeout(() => { const text = getReadableText(e.target); if (text && text.length > 1 && !text.includes('undefined')) speakTextSR(text); }, 300); }
    screenReaderToggle.addEventListener('change', () => { if (screenReaderToggle.checked) activateScreenReader(); else deactivateScreenReader(); });
    document.getElementById('resetAccessibility').addEventListener('click', () => { ['contrast', 'large-text', 'grayscale', 'dyslexia', 'reduce-motion', 'dark-mode', 'large-cursor', 'highlight-links', 'reading-guide', 'paragraph-spacing', 'no-flashing', 'focus-highlight', 'show-keys', 'screen-reader'].forEach(c => { document.body.classList.remove(c); panel.querySelectorAll('input[type="checkbox"]').forEach(cb => cb.checked = false); }); if ('speechSynthesis' in window) speechSynthesis.cancel(); });
    function copiarTexto(id) { const texto = document.getElementById(id)?.innerText; if (texto) { navigator.clipboard.writeText(texto) .then(() => alert("✅ Texto copiado al portapapeles")) .catch(() => alert("❌ No se pudo copiar")); } }
    let recognition; let isListening = false;
    document.addEventListener('DOMContentLoaded', () => { if (!('webkitSpeechRecognition' in window) && !('SpeechRecognition' in window)) { const micButton = document.getElementById('micButton'); if (micButton) { micButton.disabled = true; micButton.title = 'Navegador no compatible'; } } const micButton = document.getElementById('micButton'); if (micButton) micButton.addEventListener('click', toggleSpeechRecognition); });
    function toggleSpeechRecognition() { if (!recognition) { recognition = new (window.SpeechRecognition || window.webkitSpeechRecognition)(); recognition.lang = 'es-ES'; recognition.interimResults = false; recognition.maxAlternatives = 1; recognition.onresult = function (event) { const transcript = event.results[0][0].transcript; document.getElementById('chatInput').value = transcript; }; recognition.onerror = function (event) { console.error('Error en reconocimiento de voz:', event.error); isListening = false; updateMicButton(); }; recognition.onend = function () { isListening = false; updateMicButton(); }; } if (isListening) { recognition.stop(); } else { recognition.start(); document.getElementById('chatInput').value = 'Escuchando...'; } isListening = !isListening; updateMicButton(); }
    function updateMicButton() { const micButton = document.getElementById('micButton'); if (micButton) { micButton.textContent = isListening ? '⏹️' : '🎤'; micButton.title = isListening ? 'Detener escucha' : 'Iniciar escucha por voz'; if (isListening) { micButton.classList.add('bg-red-200'); micButton.classList.remove('bg-gray-200'); } else { micButton.classList.remove('bg-red-200'); micButton.classList.add('bg-gray-200'); } } }
    function sanitizeTextForSpeech(text) { let cleanedText = text.replace(/\*\*(.*?)\*\*/g, '$1'); cleanedText = cleanedText.replace(/\*(.*?)\*/g, '$1'); cleanedText = cleanedText.replace(/[\#\>\-]/g, ''); cleanedText = cleanedText.replace(/\n/g, ' ').replace(/\s{2,}/g, ' '); return cleanedText.trim(); }
    function updateSpeakButtonState(button, state) { if (button) { button.disabled = state === 'disabled'; button.style.opacity = state === 'disabled' ? 0.5 : 1; button.style.cursor = state === 'disabled' ? 'not-allowed' : 'pointer'; button.textContent = state === 'disabled' ? '🔊 Leyendo...' : '🔊 Escuchar'; } }
    function speakText(text, button) { if ('speechSynthesis' in window) { window.speechSynthesis.cancel(); const cleanedText = sanitizeTextForSpeech(text); const utterance = new SpeechSynthesisUtterance(cleanedText); utterance.lang = 'es-ES'; utterance.rate = 1; utterance.pitch = 1; utterance.volume = 1; updateSpeakButtonState(button, 'disabled'); utterance.onend = function () { updateSpeakButtonState(button, 'enabled'); }; utterance.onerror = function (event) { console.error('Error en síntesis de voz:', event); updateSpeakButtonState(button, 'enabled'); }; setTimeout(() => { window.speechSynthesis.speak(utterance); }, 100); } else { alert('Tu navegador no soporta la síntesis de voz.'); } }
    function googleTranslateElementInit() { new google.translate.TranslateElement( { pageLanguage: 'es', layout: google.translate.TranslateElement.InlineLayout.SIMPLE }, 'google_translate_element' ); }
  </script>
  <script type="text/javascript" src="//translate.google.com/translate_a/element.js?cb=googleTranslateElementInit"></script>
<script src="/js/roles.js"></script>
<script>
document.addEventListener('DOMContentLoaded', function() {
    const path = window.location.pathname;
    const isSuperadmin = path.includes('/r/superadmin/');
    const isAdmin = path.includes('/r/admin/');
    const isCoordinador = path.includes('/r/coordinador/');
    const isCliente = path.includes('/r/cliente/');
    const isDisInst = path.includes('/r/disenador-instruccional/');
    const isAutor = path.includes('/r/autor/');
    const isRevisor = path.includes('/r/revisor-qa/');
    const isEditor = path.includes('/r/editor/');
    const isDesaMult = path.includes('/r/desarrollador-multimedia/');
    const isAbogado = path.includes('/r/abogado/');
    const isDisGraf = path.includes('/r/disenador-grafico/');
    const isAnim2d = path.includes('/r/animador-2d/');
    const isAnim3d = path.includes('/r/animador-3d/');
    const isVideo = path.includes('/r/video/');
    const isCorrector = path.includes('/r/corrector-de-estilo/');
    const isIngeniero = path.includes('/r/ingeniero-lms/');
    const isRegistrado = path.includes('/r/registrado/');

    const allowedRoles = [];
    if (isSuperadmin) allowedRoles.push('superadmin');
    if (isAdmin) allowedRoles.push('admin');
    if (isCoordinador) allowedRoles.push('coordinador');
    if (isCliente) allowedRoles.push('cliente');
    if (isDisInst) allowedRoles.push('disenador-instruccional');
    if (isAutor) allowedRoles.push('autor');
    if (isRevisor) allowedRoles.push('revisor-qa');
    if (isEditor) allowedRoles.push('editor');
    if (isDesaMult) allowedRoles.push('desarrollador-multimedia');
    if (isAbogado) allowedRoles.push('abogado');
    if (isDisGraf) allowedRoles.push('disenador-grafico');
    if (isAnim2d) allowedRoles.push('animador-2d');
    if (isAnim3d) allowedRoles.push('animador-3d');
    if (isVideo) allowedRoles.push('video');
    if (isCorrector) allowedRoles.push('corrector-de-estilo');
    if (isIngeniero) allowedRoles.push('ingeniero-lms');
    if (isRegistrado) allowedRoles.push('registrado');

    const token = localStorage.getItem('token');
    if (!token) {
        window.location.href = '/';
        return;
    }
    
    try {
        const payload = JSON.parse(atob(token.split('.')[1]));
        const userRoles = payload.roles || [payload.role].filter(Boolean);
        if (!userRoles.some(r => allowedRoles.includes(r))) {
            window.location.href = '/';
            return;
        }
    } catch(e) {
        window.location.href = '/';
    }
});
</script>

<script>
// ==================== VERIFICACIÓN DE PERMISOS DE MENÚ ====================
(function() {
    const token = localStorage.getItem('token');
    if (!token) return;
    
    try {
        const payload = JSON.parse(atob(token.split('.')[1]));
        const permissions = payload.permissions || [];
        
        const hasPermission = (perm) => permissions.includes(perm);
        const hasAnyPermission = (perms) => perms.some(p => permissions.includes(p));
        
        const menuPermissions = {
            'menu-proyectos': ['proyectos_crear', 'proyectos_consultar'],
            'menu-crear-proyecto': ['proyectos_crear'],
            'menu-entidades': ['autor_crear', 'diseno_instruccional_crear'],
            'menu-crear-entidad': ['autor_crear', 'diseno_instruccional_crear'],
            'menu-plan-estudio': ['proyectos_planes_formacion_listar', 'diseno_instruccional_ver'],
            'menu-crear-plan': ['diseno_instruccional_crear'],
            'menu-cursos': ['proyectos_cursos_listar'],
            'menu-crear-curso': ['autor_crear'],
            'menu-modulos': ['proyectos_modulos_listar'],
            'menu-crear-modulo': ['autor_crear', 'diseno_instruccional_crear'],
            'menu-unidades': ['proyectos_unidades_listar'],
            'menu-crear-unidad': ['autor_crear', 'diseno_instruccional_crear'],
            'menu-tareas': ['proyectos_tareas_listar'],
            'menu-crear-tarea': ['autor_crear'],
            'menu-evaluaciones': ['proyectos_evaluaciones_listar'],
            'menu-crear-evaluacion': ['autor_crear'],
            'menu-fases': ['proyectos_fases_etapas_gestionar'],
            'menu-cronogramas': ['proyectos_cronogramas_crear'],
            'menu-calendario': ['proyectos_calendario_ver'],
            'menu-usuarios': ['usuarios_crear'],
            'menu-clientes': ['usuarios_crear'],
            'menu-crm': ['usuarios_crear'],
            'menu-roles': ['roles_permisos_gestionar'],
            'menu-drive': ['archivos_drive_personal_ver', 'archivos_drive_global_ver'],
            'menu-ia': ['ia_produccion_imagen', 'ia_produccion_audio', 'ia_linguistica_usar'],
            'menu-canvas': ['herramientas_canvas_usar'],
            'menu-Office': ['herramientas_Office_usar'],
            'menu-auditoria': ['seguridad_auditoria_ver'],
            'menu-bitacora': ['seguridad_bitacora_usuarios_ver'],
            'menu-estadisticas': ['reportes_estadisticas_ver'],
            'menu-metricas': ['reportes_metricas_ver'],
            'menu-diseno-instruccional': ['diseno_instruccional_ver', 'diseno_instruccional_crear'],
            'menu-autor-contenido': ['autor_ver', 'autor_crear'],
            'menu-microcursos': ['capacitacion_microcursos_ver'],
            'menu-tutoriales': ['capacitacion_tutoriales_ver'],
            'menu-faq': ['capacitacion_faq_ver'],
        };
        
        Object.entries(menuPermissions).forEach(([id, required]) => {
            const el = document.getElementById(id);
            if (el && !hasAnyPermission(required)) {
                el.style.display = 'none';
            }
        });
    } catch(e) {}
})();
</script>

</body>
</html>
